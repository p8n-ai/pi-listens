      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "sarvamai": "^1.1.7"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typebox": "^1.1.38",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
